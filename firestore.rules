rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Safe role lookup — returns null if user doc doesn't exist yet
    function userRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin()    { return isSignedIn() && userRole() == 'admin'; }
    function isOperator() { return isSignedIn() && userRole() == 'operator'; }
    function isDriver()   { return isSignedIn() && userRole() == 'driver'; }
    function isClient()   { return isSignedIn() && userRole() == 'client'; }

    // ── users ──────────────────────────────────────────────────────────────────
    match /users/{uid} {
      // Any signed-in user can read their own doc; admin can read all
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // Only the user themselves can create/update their own doc
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // ── shipments ──────────────────────────────────────────────────────────────
    match /shipments/{shipmentId} {
      // All authenticated users can read shipments
      allow read: if isSignedIn();
      // Admin + operator + client can create
      allow create: if isAdmin() || isOperator() || isClient();
      // Admin + operator + driver + client can update
      allow update: if isAdmin() || isOperator() || isDriver() || isClient();
      allow delete: if false;
    }

    // ── drivers ───────────────────────────────────────────────────────────────
    match /drivers/{driverId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() || isOperator();
      allow update: if isAdmin() || isOperator() || isDriver();
      allow delete: if false;
    }

    // ── ai_insights ───────────────────────────────────────────────────────────
    match /ai_insights/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isOperator();
    }
  }
}
